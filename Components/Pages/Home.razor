@page "/"
@layout ShopLayout
@inject IJSRuntime JSRuntime
@using System.Linq
@implements IDisposable

<style>
    html, body {
        margin: 0 !important;
        padding: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        overflow: hidden !important;
        background: #f8f8f8 !important;
    }
</style>

<div class="shop-shell">
    <div class="app-frame">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M35,65 C35,76 44,85 55,85 C66,85 75,76 75,65 C75,55 67,46.5 57.5,45.2 L57.5,25 C57.5,19.5 62,15 67.5,15 C73,15 77.5,19.5 77.5,25" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <nav class="sidebar-nav">
                @foreach (var item in NavigationItems)
                {
                    <button class="nav-item @(item.IsActive ? "active" : "")" aria-label="@item.Label" @onclick="() => SetActiveItem(item)">
                        <span class="nav-icon">
                            @if (item.IconName == "home")
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                    <polyline points="9 22 9 12 15 12 15 22" />
                                </svg>
                            }
                            else if (item.IconName == "explore")
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="7" height="7" rx="1.5" />
                                    <rect x="14" y="3" width="7" height="7" rx="1.5" />
                                    <rect x="14" y="14" width="7" height="7" rx="1.5" />
                                    <rect x="3" y="14" width="7" height="7" rx="1.5" />
                                </svg>
                            }
                            else if (item.IconName == "boutique")
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="8" cy="21" r="1.5" />
                                    <circle cx="19" cy="21" r="1.5" />
                                    <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12" />
                                </svg>
                            }
                            else if (item.IconName == "tags")
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l5.58-5.58c.94-.94.94-2.48 0-3.42L12 2z" />
                                    <line x1="7" y1="7" x2="7.01" y2="7" stroke-width="3" stroke-linecap="round" />
                                </svg>
                            }
                            else if (item.IconName == "favoris")
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
                                </svg>
                            }
                        </span>
                    </button>
                }
            </nav>
            <div class="sidebar-profile">
                <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=400&q=80" alt="Profil utilisateur" />
            </div>
        </aside>

        <main class="hero-panel">
            <div class="scene-stage">
                <div class="center-controls">
                    <div class="hero-brand">shop</div>
                    <div class="hero-search">
                        <input type="search" 
                               placeholder="Que recherchez-vous aujourd'hui ?" 
                               aria-label="Recherche" 
                               @bind="SearchQuery" 
                               @bind:event="oninput"
                               @onkeydown="HandleSearchKeyDown" />
                        <div class="search-actions">
                            <button type="button" 
                                    class="search-mic @(IsListening ? "listening" : "")" 
                                    aria-label="Dicter" 
                                    @onclick="ToggleListening">
                                @if (IsListening)
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke="red" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="4" y="4" width="16" height="16" rx="2" fill="red" />
                                    </svg>
                                }
                                else
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z" />
                                        <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
                                        <line x1="12" y1="19" x2="12" y2="22" />
                                    </svg>
                                }
                            </button>
                            <button type="button" 
                                    class="search-action" 
                                    aria-label="Rechercher" 
                                    @onclick="TriggerSearch">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
                @if (IsLoading)
                {
                    <div class="loader-wrap">
                        <div class="pulse-ring"></div>
                        <span class="loader-text">Recherche intelligente en cours...</span>
                    </div>
                }
                else if (Scenes.Count == 0)
                {
                    <div class="loader-wrap">
                        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#8c9ba5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 0.5rem;">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <span class="loader-text">Aucun produit trouvé pour votre recherche.</span>
                    </div>
                }
                else
                {
                    @foreach (var scene in Scenes)
                    {
                        <div class="scene-wrap @(GetSceneState(scene.Index))">
                            @foreach (var product in scene.Products)
                            {
                                <div class="floating-card @(product.HasCard ? "card" : "bare") @(product.Position)">
                                    <div class="card-image" style="background-image: url('@product.ImageUrl');"></div>
                                    @if (product.HasCard)
                                    {
                                        <div class="card-copy">
                                            <div class="card-title">@product.Title</div>
                                            @if (product.Rating > 0)
                                            {
                                                <div class="card-rating">
                                                    <span class="stars">★★★★★</span>
                                                    <span class="reviews">(@product.Reviews)</span>
                                                </div>
                                            }
                                            <div class="card-subtitle">@product.Subtitle</div>
                                            <div class="card-price">@product.Price</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="bare-label">
                                            <span>@product.Title</span>
                                            <small>@product.Price</small>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
                @if (!IsLoading && Scenes.Count > 0)
                {
                    <div class="progress-row">
                        @for (var i = 0; i < Scenes.Count; i++)
                        {
                            <div class="progress-pill @(i == CurrentScene ? "active" : i < CurrentScene ? "completed" : "")">
                                <div class="progress-fill" style="width:@GetProgressWidth(i)"></div>
                            </div>
                        }
                    </div>
                }
            </div>
        </main>
    </div>
</div>

@code {
    private readonly List<NavItem> NavigationItems = new()
    {
        new NavItem("Accueil", "home", false),
        new NavItem("Explorer", "explore", false),
        new NavItem("Boutique", "boutique", true),
        new NavItem("Tags", "tags", false),
        new NavItem("Favoris", "favoris", false)
    };

    private readonly List<Scene> Scenes = new();

    private const int SceneDurationMs = 5800;
    private readonly System.Timers.Timer _sceneTimer;
    private double _elapsedMs;
    private int _currentScene;
    private int _previousScene;

    private bool IsLoading { get; set; } = true;
    private bool IsListening { get; set; } = false;
    private string SearchQuery { get; set; } = "";

    public Home()
    {
        _sceneTimer = new System.Timers.Timer(60);
        _sceneTimer.Elapsed += async (_, _) => await InvokeAsync(OnTickAsync);
        _sceneTimer.AutoReset = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await FetchProductsAsync("");
        _sceneTimer.Start();
    }

    private Task OnTickAsync()
    {
        if (IsLoading || Scenes.Count == 0) return Task.CompletedTask;

        _elapsedMs += 60;
        if (_elapsedMs >= SceneDurationMs)
        {
            _elapsedMs -= SceneDurationMs;
            _previousScene = _currentScene;
            _currentScene = (_currentScene + 1) % Scenes.Count;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private int CurrentScene => Scenes.Count > 0 ? _currentScene : 0;

    private string GetSceneState(int index)
    {
        return index == CurrentScene ? "active" : index == _previousScene ? "exiting" : "hidden";
    }

    private string GetProgressWidth(int index)
    {
        if (Scenes.Count == 0) return "0%";

        if (index < CurrentScene)
        {
            return "100%";
        }

        if (index == CurrentScene)
        {
            return $"{Math.Round(Math.Min(1.0, _elapsedMs / SceneDurationMs) * 100)}%";
        }

        return "0%";
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await TriggerSearch();
        }
    }

    private async Task TriggerSearch()
    {
        await FetchProductsAsync(SearchQuery);
    }

    private async Task ToggleListening()
    {
        if (IsListening)
        {
            IsListening = false;
        }
        else
        {
            IsListening = true;
            var dotNetObjRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("window.speechRecognition.start", dotNetObjRef);
        }
    }

    [JSInvokable]
    public void ReceiveSpeech(string text)
    {
        SearchQuery = text;
        IsListening = false;
        StateHasChanged();
        
        _ = InvokeAsync(() => FetchProductsAsync(SearchQuery));
    }

    private async Task FetchProductsAsync(string query)
    {
        try
        {
            IsLoading = true;
            StateHasChanged();

            using var httpClient = new HttpClient();
            var requestPayload = new GradioRequest
            {
                Data = new object[] { query },
                ApiName = "/search_products"
            };

            var jsonContent = System.Text.Json.JsonSerializer.Serialize(requestPayload);
            var content = new StringContent(jsonContent, System.Text.Encoding.UTF8, "application/json");

            var response = await httpClient.PostAsync("https://drichdev-marketplace-nlp-api.hf.space/api/predict", content);
            bool success = false;
            
            if (response.IsSuccessStatusCode)
            {
                var responseString = await response.Content.ReadAsStringAsync();
                var gradioResponse = System.Text.Json.JsonSerializer.Deserialize<GradioResponse>(responseString);

                if (gradioResponse?.Data != null && gradioResponse.Data.Length > 0)
                {
                    var tableElement = gradioResponse.Data[0];
                    var table = System.Text.Json.JsonSerializer.Deserialize<GradioTable>(tableElement.GetRawText());

                    if (table?.Data != null && table.Data.Length > 0)
                    {
                        var newProducts = new List<FloatingProduct>();
                        string[] positions = new[] { "top-left", "top-center", "top-right", "left", "right", "bottom-left", "bottom-center", "bottom-right" };

                        for (int i = 0; i < table.Data.Length; i++)
                        {
                            var row = table.Data[i];
                            if (row.Length < 7) continue;

                            string name = row[1].GetString() ?? "";
                            string category = row[2].GetString() ?? "";

                            double priceVal = 0;
                            if (row[3].ValueKind == System.Text.Json.JsonValueKind.Number)
                            {
                                priceVal = row[3].GetDouble();
                            }
                            else if (row[3].ValueKind == System.Text.Json.JsonValueKind.String && double.TryParse(row[3].GetString(), out double p))
                            {
                                priceVal = p;
                            }

                            string price = $"€{priceVal}";
                            string imageUrl = row[5].GetString() ?? "";
                            string description = row[6].GetString() ?? "";

                            double rating = 0;
                            if (row.Length > 7)
                            {
                                if (row[7].ValueKind == System.Text.Json.JsonValueKind.Number)
                                    rating = row[7].GetDouble();
                                else if (row[7].ValueKind == System.Text.Json.JsonValueKind.String && double.TryParse(row[7].GetString(), out double r))
                                    rating = r;
                            }

                            string reviews = "0";
                            if (row.Length > 8)
                            {
                                if (row[8].ValueKind == System.Text.Json.JsonValueKind.Number)
                                    reviews = row[8].GetInt32().ToString();
                                else if (row[8].ValueKind == System.Text.Json.JsonValueKind.String)
                                    reviews = row[8].GetString() ?? "0";
                            }

                            string position = positions[i % positions.Length];
                            bool hasCard = (i % 2 == 0);

                            newProducts.Add(new FloatingProduct(name, category, price, imageUrl, position, hasCard, rating, reviews));
                        }

                        if (newProducts.Count > 0)
                        {
                            var newScenes = new List<Scene>();
                            int itemsPerScene = 8;
                            int sceneCount = (int)Math.Ceiling((double)newProducts.Count / itemsPerScene);

                            for (int s = 0; s < sceneCount; s++)
                            {
                                var sceneProducts = newProducts.Skip(s * itemsPerScene).Take(itemsPerScene).ToList();
                                for (int idx = 0; idx < sceneProducts.Count; idx++)
                                {
                                    sceneProducts[idx] = sceneProducts[idx] with { Position = positions[idx % positions.Length] };
                                }
                                newScenes.Add(new Scene(s, sceneProducts));
                            }

                            Scenes.Clear();
                            Scenes.AddRange(newScenes);
                            _currentScene = 0;
                            _previousScene = newScenes.Count - 1;
                            _elapsedMs = 0;
                            success = true;
                        }
                    }
                }
            }
            
            if (!success)
            {
                LoadFallbackProducts();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching products: {ex.Message}");
            LoadFallbackProducts();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void LoadFallbackProducts()
    {
        var fallbackProducts = new List<FloatingProduct>
        {
            new("Dream Night Serum with B...", "Soin de nuit", "€68", "https://images.unsplash.com/photo-1535585209827-a15fcdbc4c2d?auto=format&fit=crop&w=700&q=80", "top-left", true, 4.8, "236"),
            new("Sac à main", "Cuir bleu ciel", "€159", "https://images.unsplash.com/photo-1548036328-c9fa89d128fa?auto=format&fit=crop&w=700&q=80", "top-center", false),
            new("Sneakers", "Style rétro", "€120", "https://images.unsplash.com/photo-1549298916-b41d501d3772?auto=format&fit=crop&w=700&q=80", "top-right", false),
            new("Lunettes de soleil", "Teinte verte", "€145", "https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&w=700&q=80", "right", false),
            new("Cookware Set", "Casseroles blanches", "€240", "https://images.unsplash.com/photo-1584269600464-37b1b58a9fe7?auto=format&fit=crop&w=700&q=80", "top-right", true, 4.9, "39K"),
            new("Organic Dark Chocolate 8...", "Chocolat noir", "€9.50", "https://images.unsplash.com/photo-1606313564200-e75d5e30476c?auto=format&fit=crop&w=700&q=80", "bottom-left", true, 4.7, "54"),
            new("Gourde isotherme", "Acier inoxydable", "€45", "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&w=700&q=80", "bottom-center", false),
            new("Terry Stripe Slippers (Bone...", "Mousse à mémoire", "€35", "https://images.unsplash.com/photo-1608256246200-53e635b5b65f?auto=format&fit=crop&w=700&q=80", "bottom-right", true, 5.0, "2")
        };
        
        var newScenes = new List<Scene>();
        int itemsPerScene = 8;
        int sceneCount = (int)Math.Ceiling((double)fallbackProducts.Count / itemsPerScene);
        
        string[] positions = new[] { "top-left", "top-center", "top-right", "left", "right", "bottom-left", "bottom-center", "bottom-right" };
        for (int s = 0; s < sceneCount; s++)
        {
            var sceneProducts = fallbackProducts.Skip(s * itemsPerScene).Take(itemsPerScene).ToList();
            for (int idx = 0; idx < sceneProducts.Count; idx++)
            {
                sceneProducts[idx] = sceneProducts[idx] with { Position = positions[idx % positions.Length] };
            }
            newScenes.Add(new Scene(s, sceneProducts));
        }

        Scenes.Clear();
        Scenes.AddRange(newScenes);
        _currentScene = 0;
        _previousScene = newScenes.Count - 1;
        _elapsedMs = 0;
    }

    private void SetActiveItem(NavItem selectedItem)
    {
        foreach (var item in NavigationItems)
        {
            item.IsActive = (item == selectedItem);
        }
    }

    public void Dispose()
    {
        _sceneTimer.Stop();
        _sceneTimer.Dispose();
    }

    private sealed class NavItem
    {
        public string Label { get; }
        public string IconName { get; }
        public bool IsActive { get; set; }

        public NavItem(string label, string iconName, bool isActive)
        {
            Label = label;
            IconName = iconName;
            IsActive = isActive;
        }
    }

    private sealed record Scene(int Index, List<FloatingProduct> Products);
    private sealed record FloatingProduct(
        string Title,
        string Subtitle,
        string Price,
        string ImageUrl,
        string Position,
        bool HasCard = true,
        double Rating = 0,
        string Reviews = ""
    );

    public class GradioRequest
    {
        [System.Text.Json.Serialization.JsonPropertyName("data")]
        public object[]? Data { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("api_name")]
        public string ApiName { get; set; } = "/search_products";
    }

    public class GradioResponse
    {
        [System.Text.Json.Serialization.JsonPropertyName("data")]
        public System.Text.Json.JsonElement[]? Data { get; set; }
    }

    public class GradioTable
    {
        [System.Text.Json.Serialization.JsonPropertyName("headers")]
        public string[]? Headers { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("data")]
        public System.Text.Json.JsonElement[][]? Data { get; set; }
    }
}
